	Print_Item_State()
	{
		# Print a single line item with green bullet, description "$1", green separator and state "$2"
		# state should contain color and format codes as needed
        local subtitle="$1"
        local state="$2"
		local width="${3:-}"
		local color="${aCOLOUR[$WHITE]}"
        printf "%b%b %-${width}b %b %b\n" \
